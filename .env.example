# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://dev.planetmotors.ca

# ─── Clerk ───────────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect paths (Next.js App Router)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/account

# ─── Neon / Postgres ─────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
# After setting, run the migration: psql $DATABASE_URL -f db/migrations/001_saved_vehicles.sql
DATABASE_URL=postgres://[user]:[password]@[host]/[dbname]?sslmode=require

# ─── Cloudinary ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=planet-motors

# ─── Upstash Redis ───────────────────────────────────────────────────────────
# https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Deposit amount (cents CAD) ───────────────────────────────────────────────
STRIPE_DEPOSIT_AMOUNT_CENTS=50000

# ─── RouteOne / Dealertrack ──────────────────────────────────────────────────
ROUTEONE_API_URL=https://...
ROUTEONE_DEALER_ID=...
ROUTEONE_API_KEY=...
ROUTEONE_WEBHOOK_SECRET=...
DEALERTRACK_API_URL=https://...
DEALERTRACK_DEALER_ID=...
DEALERTRACK_API_KEY=...
DEALERTRACK_WEBHOOK_SECRET=...

# ─── AutoRaptor CRM ──────────────────────────────────────────────────────────
AUTORAPTOR_API_URL=https://app.autoraptor.com/api
AUTORAPTOR_API_KEY=...
AUTORAPTOR_WEBHOOK_SECRET=...

# ─── Provider Webhooks ───────────────────────────────────────────────────────
DELIVERY_WEBHOOK_SECRET=...
TRADEIN_WEBHOOK_SECRET=...

# ─── Internal revalidation ───────────────────────────────────────────────────
REVALIDATE_SECRET=...
OPS_API_SECRET=...

# ─── Feature flags ───────────────────────────────────────────────────────────
# Set to '1' in production when integrations are live.
# Leave unset or '0' to keep integrations in stub/logging mode.
ENABLE_ROUTEONE=0
ENABLE_DEALERTRACK=0
ENABLE_AUTORAPTOR=0
ENABLE_STRIPE_DEPOSITS=0

# Dev only — allow any image origin through next/image proxy
NEXT_PUBLIC_ALLOW_ALL_IMAGE_HOSTS=

# ─── Ops alert thresholds ────────────────────────────────────────────────────
ALERT_FINANCE_DEAD_LETTER_MAX=0
ALERT_WEBHOOK_FAILED_MAX=0
ALERT_CRM_DEAD_LETTER_MAX=0
ALERT_DELIVERY_FAILED_MAX=0
ALERT_INVENTORY_STALE_HOURS_MAX=24
